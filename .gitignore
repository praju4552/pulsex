# 📦 Dependency directories
node_modules/
backend-node/node_modules/

# 🛠️ Compiled output folders
dist-ssr/
build/

# 🔐 Local Environment Secrets - NEVER commit these!
.env
.env.*
!.env.example
backend-node/.env
backend-node/.env.*
!backend-node/.env.example

# 🗑️ Temporary and upload files — server-side temp storage, never commit
uploads/
# Ignore all files inside uploads/ subdirs but allow git to traverse the dirs,
# so the !.gitkeep exceptions below can take effect.
backend-node/uploads/*
!backend-node/uploads/*/
backend-node/uploads/*/*
!backend-node/uploads/*/.gitkeep
*.zip

# 📋 Logs and OS files
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# 🛑 Throwaway/Debug Scripts we used earlier
delete_scan_*.py
tsc_error_*.txt
*.bat
