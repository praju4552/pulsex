generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

enum Role {
  USER
  SUPER_ADMIN
  INSTITUTION_ADMIN
}

model VerificationCode {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

// ─── Prototyping Service Orders ───────────────────────────────────────────────

enum PrototypingOrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  QUALITY_CONTROL
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

model PrototypingOrder {
  id              String                  @id @default(uuid())
  orderRef        String                  @unique @default(cuid())
  salesOrderId    String?                 @unique
  invoiceId       String?                 @unique
  projectId       String?                 @unique
  jobId           String?                 @unique

  // Customer contact (may be guest, so stored directly)
  firstName       String
  lastName        String
  email           String
  phone           String

  // Shipping address
  streetAddress   String
  apartment       String?
  city            String
  state           String
  zip             String
  country         String

  // PCB Specs (stored as JSON)
  serviceType     String   // "PCB Printing" | "3D Printing"
  specifications  Json     // Full PCBSpec object or 3D spec
  specSummary     String   // Human-readable summary for admin

  // Shipping method
  shippingMethod  String
  shippingCost    Int

  // Totals (in paise / smallest unit, stored as Int)
  pcbPrice        Int
  totalAmount     Int

  // Status
  orderStatus     PrototypingOrderStatus @default(PENDING)
  paymentStatus   PaymentStatus          @default(UNPAID)
  adminNotes      String?

  // Optional link to user account
  userId          String?
  user            PrototypingUser? @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
}

model PrototypingUser {
  id          String   @id @default(uuid())
  role        Role     @default(USER)
  name        String
  email       String   @unique
  phone       String?  @unique
  password    String?
  googleId    String?  @unique
  whatsappId  String?  @unique
  credits     Int      @default(0) // Moved from old User model
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  
  // Primary address fields
  streetAddress String?
  apartment     String?
  city          String?
  state         String?
  zip           String?
  country       String?

  // Secondary address fields
  secondaryLabel         String?  // e.g. "Office", "Home 2"
  secondaryStreetAddress String?
  secondaryApartment     String?
  secondaryCity          String?
  secondaryState         String?
  secondaryZip           String?
  secondaryCountry       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders        PrototypingOrder[]
  threeDFiles   ThreeDFile[]
  threeDOrders  ThreeDOrder[]
  laserFiles    LaserCuttingFile[]
  laserOrders   LaserCuttingOrder[]

  @@index([email])
}

// ─── 3D Printing Specialized Models ──────────────────────────────────────────

model ThreeDFile {
  id           String   @id @default(uuid())
  userId       String?
  filePath     String
  fileType     String
  fileSize     Int
  uploadStatus String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  createdAt    DateTime @default(now())
  
  user         PrototypingUser? @relation(fields: [userId], references: [id])
  metadata     ThreeDMetadata?
  config       ThreeDPrintConfig?
  order        ThreeDOrder?

  @@index([userId])
  @@index([createdAt])
}

model ThreeDMetadata {
  id                 String   @id @default(uuid())
  fileId             String   @unique
  volume             Float?
  surfaceArea        Float?
  width              Float?
  height             Float?
  depth              Float?
  triangleCount      Int?
  estimatedPrintTime Float?   // In minutes
  screenshotUrl      String?

  file               ThreeDFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

model ThreeDPrintConfig {
  id                 String   @id @default(uuid())
  fileId             String   @unique
  material           String
  infill             Int
  scale              Float    @default(1.0)
  layerHeight        Float
  finish             String
  color              String?

  file               ThreeDFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

model ThreeDOrder {
  id                 String                 @id @default(uuid())
  userId             String?
  fileId             String                 @unique
  configId           String?
  price              Int                    // In cents/paise
  quantity           Int                    @default(1)
  status             PrototypingOrderStatus @default(PENDING)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  user               PrototypingUser?       @relation(fields: [userId], references: [id])
  file               ThreeDFile             @relation(fields: [fileId], references: [id])
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─── Managed Pricing Tables ──────────────────────────────────────────────────

model PrintMaterial {
  id           String @id @default(uuid())
  name         String @unique
  density      Float  // g/cm3
  costPerGram  Float  // in currency units
}

model MachineConfig {
  id           String @id @default(uuid())
  machineName  String @unique
  costPerHour  Float  // in currency units
  maxVolume    String // e.g., "250x210x210"
}

model PricingConfig {
  id        String   @id @default(uuid())
  key       String   @unique // e.g., '3d_pricing', 'laser_pricing', 'pcb_pricing'
  value     Json     // Arbitrary JSON structure for rates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sequence {
  id    String @id @default(uuid())
  type  String @unique // "SO", "INV", "PID", "PCB", "3D", "LC"
  count Int    @default(0)
}


// ─── Laser Cutting Models ────────────────────────────────────────────────────

model LaserCuttingFile {
  id           String   @id @default(uuid())
  userId       String?
  filePath     String
  fileName     String
  fileType     String   // dxf, svg, pdf, ai, png, jpg, bmp
  fileSize     Int
  uploadStatus String   @default("UPLOADED") // UPLOADED, PROCESSING, COMPLETED, FAILED
  createdAt    DateTime @default(now())

  user         PrototypingUser? @relation(fields: [userId], references: [id])
  config       LaserCuttingConfig?
  order        LaserCuttingOrder?

  @@index([userId])
  @@index([createdAt])
}

model LaserCuttingConfig {
  id           String @id @default(uuid())
  fileId       String @unique
  serviceType  String // "cutting" | "engraving" | "both"
  material     String // wood_mdf, wood_plywood, hardwood, acrylic_cast, acrylic_extruded, leather, fabric, cork, felt, rubber
  thickness    Float  // in mm
  width        Float  // in mm (design area)
  height       Float  // in mm (design area)
  quantity     Int    @default(1)
  finish       String @default("standard") // standard, polished, painted
  urgency      String @default("standard") // standard, rush_24h

  file         LaserCuttingFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

model LaserCuttingOrder {
  id        String                 @id @default(uuid())
  userId    String?
  fileId    String                 @unique
  configId  String?
  price     Int                    // in paise
  quantity  Int                    @default(1)
  status    PrototypingOrderStatus @default(PENDING)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  user      PrototypingUser?       @relation(fields: [userId], references: [id])
  file      LaserCuttingFile       @relation(fields: [fileId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─── Service Inquiries (SEM/TEM & Project Dev) ───────────────────────────────

enum InquiryServiceType {
  SEM_TEM
  PROJECT_DEV
  PCB_DESIGN
}

enum InquiryType {
  REQUEST_CALLBACK
  GET_QUOTE
}

enum InquiryStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED
}

model ServiceInquiry {
  id            String              @id @default(uuid())
  serviceType   InquiryServiceType
  inquiryType   InquiryType
  name          String
  email         String
  phone         String
  requirements  String              @db.Text
  filePath      String?             // optional uploaded file
  fileName      String?
  status        InquiryStatus       @default(NEW)
  adminNotes    String?             @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([serviceType])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id                String   @id @default(cuid())
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  razorpaySignature String?
  amount            Int
  currency          String   @default("INR")
  status            String   @default("CREATED")
  orderType         String
  orderIds          Json
  userId            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
